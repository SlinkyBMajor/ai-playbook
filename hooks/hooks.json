{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inject-additional-context.sh \"${CLAUDE_PLUGIN_ROOT}/shared/context7-instructions.md\" SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/set-distillation-sentinel.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-distillation-sentinel.sh \"${CLAUDE_PLUGIN_ROOT}/shared/distillation-pending-reminder.md\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
